{
  "stage_0": {
    "hamming_threshold": 24,
    "histogram_threshold": 0.30,
    "aspect_ratio_threshold": 0.05,
    "clip_threshold": 0.60
  },
  "gates": {
    "min_ssim_similarity": 0.30,
    "min_color_similarity": 0.35,
    "min_cropped_ssim_similarity": 0.40,
    "min_cropped_color_similarity": 0.40,
