  "enable_sift": true,
  "weights": {
    "containment": {
      "features": 0.35,
      "ssim": 0.35,
      "color": 0.15,
      "clip": 0.15
    },
    "full_frame": {
      "hashes": 0.25,
      "ssim": 0.25,
      "color": 0.20,
      "clip": 0.20,
      "jpeg": 0.05,
      "aspect_ratio": 0.05
    },
    "resize_duplicate_email": {
      "hashes": 0.25,
      "ssim": 0.25,
      "color": 0.20,
      "aspect_ratio": 0.20,
      "jpeg": 0.10
    }
  }
